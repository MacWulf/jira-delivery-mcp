{
  "name": "@jira-delivery-mcp/jira-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Local Jira MCP server for Jira Delivery MCP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "smoke": "tsx src/smoke.ts",
    "validate:live": "tsx src/live-test.ts --confirm-live",
    "validate:skill-metadata": "tsx src/skill-metadata-live-test.ts --confirm-live",
    "validate:skill-metadata-demo": "tsx src/skill-metadata-demo-live-test.ts --confirm-live",
    "seed:sample-roadmap": "tsx src/capability-roadmap-live-seed.ts --confirm-live",
    "validate:dependencies": "tsx src/dependency-control-live-test.ts",
    "validate:dependency-drift": "tsx src/dependency-drift-live-test.ts",
    "validate:workflow-apply": "tsx src/workflow-admin-live-apply.ts --confirm-live"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "dotenv": "17.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
